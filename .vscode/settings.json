{
  "foam.openDailyNote.onVSCodeStartup": false,
  "foam.files.exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/out/**",
    "raw/**"
  ],
  "foam.graph.style": {
    "background": "#202020",
    "node": {
      "regular": { "color": "#277da1" },
      "placeholder": { "color": "#aa5042" }
    }
  },
  "editor.defaultFormatter": "yzhang.markdown-all-in-one",
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  }
}
